# Plans — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# -------------------------------------------------------
# Supabase — get these from your project's API settings
# at https://supabase.com/dashboard/project/<your-project>/settings/api
# -------------------------------------------------------

# Project URL — safe to expose to the client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose to the client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY. NEVER prefix with NEXT_PUBLIC_.
# Used for privileged operations (e.g. admin queries bypassing RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------------------
# App
# -------------------------------------------------------

# Public URL of the app (used for generating join links, OAuth redirects, etc.)
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000
